# Copy this file to .env.local and fill in your Firebase project values
# Get these from: Firebase Console > Project Settings > Your Apps > Web App > SDK Setup

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# WhatsApp
# International format without + prefix (e.g. Nepal: 977 then the number)
VITE_WHATSAPP_NUMBER=9779800000000

# Google Reviews (optional — pulls real Google reviews into the Testimonials admin)
# 1. Google Cloud Console → Enable "Places API (New)"
# 2. Create API key → restrict to your domain
# 3. Find your Place ID: search your business on Google Maps → copy from URL
VITE_GOOGLE_PLACES_API_KEY=your_google_api_key_here
VITE_GOOGLE_PLACE_ID=ChIJXXXXXXXXXXXXXXXX

# EmailJS — sends email to tiptoesportshub@gmail.com on every Enroll / Contact submission
# Free plan: 200 emails/month. Setup steps:
# 1. Sign up free at https://www.emailjs.com
# 2. Email Services → Add Service → Gmail → connect tiptoesportshub@gmail.com → copy the Service ID
# 3. Email Templates → Create Template → set Subject to: {{subject}}
#    In the Content/Body field switch to HTML and paste ONLY this one line: {{{html_body}}}
#    Save → copy the Template ID
# 4. Account → API Keys → copy your Public Key
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx

# Cloudinary (free photo uploads for coaches — free plan, no credit card needed)
# 1. Create free account at cloudinary.com
# 2. Dashboard → copy your Cloud Name
# 3. Settings → Upload → Upload presets → Add preset → set to "Unsigned" → save
# 4. Copy the preset name
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_name_here
